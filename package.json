"scripts": {
  "preinstall": "sh -c 'rm -f package-lock.json yarn.lock; case \"$npm_config_user_agent\" in pnpm/*) ;; *) echo \"Use pnpm instead\" >&2; exit 1 ;; esac'",
  "build": "pnpm run typecheck && pnpm -r --filter \"./scripts\" --if-present run build",
  "typecheck:libs": "echo 'Skipping lib builds'",
  "typecheck": "pnpm -r --filter \"./scripts\" --if-present run typecheck",
  "start": "pnpm --filter @workspace/scripts start"
}

